{
  "name": "layer",
  "version": "2.0.9",
  "private": true,
  "scripts": {
    "web": "pnpm -F @layer/web",
    "app": "pnpm -F @layer/mobile",
    "dev": "pnpm -r --parallel run dev",
    "lint": "pnpm -r --parallel run lint",
    "build": "pnpm -r --parallel run build",
    "build:app": "pnpm build --filter=\"...{./apps/app}\"",
    "build:web": "pnpm build --filter=\"...{./apps/web}\"",
    "version:patch": "lerna version patch --no-git-tag-version",
    "version:minor": "lerna version minor --no-git-tag-version",
    "version:major": "lerna version major --no-git-tag-version"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "18 || 19",
        "react-dom": "18 || 19",
        "@types/react": "18 || 19"
      }
    }
  },
  "devDependencies": {
    "lerna": "^8.1.8"
  }
}
